# snap_to_grid(pos: vector3, step: float) — grid XZ snap, Y untouched.
# Each line: [ {vec3 pos}, {float step} ]. Components narrow to Float32.
# --- step > 0: snap x and z to the lattice, y passes through ---
[{"vec3":[3.3, 5.0, 7.7]},{"float":2.0}]
[{"vec3":[1.0, 2.0, 3.0]},{"float":1.0}]
[{"vec3":[10.4, -1.5, -10.6]},{"float":4.0}]
[{"vec3":[0.0, 0.0, 0.0]},{"float":4.0}]
[{"vec3":[-3.3, 1.25, -7.7]},{"float":2.0}]
# round-half-up ties inside snappedf
[{"vec3":[1.0, 9.0, 3.0]},{"float":2.0}]
[{"vec3":[5.0, 0.5, 15.0]},{"float":2.0}]
# non-integer step
[{"vec3":[1.3, 2.0, 4.9]},{"float":0.5}]
# --- step <= 0: the identity map (grid snap off), no snapping ---
[{"vec3":[1.234, 2.5, 3.987]},{"float":0.0}]
[{"vec3":[-3.3, 1.0, -7.7]},{"float":-1.0}]
[{"vec3":[100.5, -50.5, 0.25]},{"float":-2.0}]
