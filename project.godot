HUD="*res://game/ui/hud.gd"
Kit="*res://game/world/kit.gd"
CellRecords="*res://game/world/cell_records.gd"
GodMode="*res://game/dev/god_mode.gd"
HotReload="*res://game/dev/hot_reload.gd"
MapScreen="*res://game/ui/map_screen.gd"
SaveGame="*res://game/save/save_manager.gd"

