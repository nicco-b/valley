; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Valley"
run/main_scene="res://game/ui/title.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[display]

window/size/viewport_width=1400
window/size/viewport_height=1120

[autoload]

WorldState="*res://game/state/world_state.gd"
GameClock="*res://game/world/game_clock.gd"
Terrain="*res://game/world/terrain.gd"
Weather="*res://game/world/weather.gd"
InteractionField="*res://game/world/interaction_field.gd"
Records="*res://game/data/records.gd"
HUD="*res://game/ui/hud.gd"
Items="*res://game/items/items.gd"
Kit="*res://game/world/kit.gd"
CellRecords="*res://game/world/cell_records.gd"
GodMode="*res://game/dev/god_mode.gd"
HotReload="*res://game/dev/hot_reload.gd"
MapScreen="*res://game/ui/map_screen.gd"
SaveGame="*res://game/save/save_manager.gd"
Settings="*res://game/ui/settings.gd"
PauseMenu="*res://game/ui/pause_menu.gd"
Dialogue="*res://game/dialogue/dialogue.gd"
Journal="*res://game/quests/journal.gd"

[shader_globals]

wind_strength={
"type": "float",
"value": 0.12
}
trace_map={
"type": "sampler2D",
"value": ""
}
trace_center={
"type": "vec2",
"value": Vector2(0, 0)
}
trace_size={
"type": "float",
"value": 80.0
}

