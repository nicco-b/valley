; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Valley"
run/main_scene="res://game/ui/title.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
; Boot splash: no engine logo — plain gouache paper (UITheme.PAPER)
; until the title fades in. PLACEHOLDER for her painted splash card
; (drop an image at boot_splash/image when it exists).
boot_splash/show_image=false
boot_splash/bg_color=Color(0.96, 0.93, 0.865, 1)

[display]

window/size/viewport_width=1400
window/size/viewport_height=1120
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[autoload]

WorldState="*res://game/state/world_state.gd"
GameClock="*res://game/world/game_clock.gd"
FocusThrottle="*res://game/world/focus_throttle.gd"
Terrain="*res://game/world/terrain.gd"
Rng="*res://game/sim/rng.gd"
Nav="*res://game/world/nav.gd"
Weather="*res://game/world/weather.gd"
Climate="*res://game/world/climate.gd"
Hydrology="*res://game/world/hydrology.gd"
WaterField="*res://game/world/water_field.gd"
WaterWaves="*res://game/world/water_waves.gd"
SeaSwell="*res://game/world/sea_swell.gd"
FloraLife="*res://game/world/flora_life.gd"
InteractionField="*res://game/world/interaction_field.gd"
SandField="*res://game/world/sand_field.gd"
Records="*res://game/data/records.gd"
Cards="*res://game/data/cards.gd"
HUD="*res://game/ui/hud.gd"
Items="*res://game/items/items.gd"
Kit="*res://game/world/kit.gd"
CellRecords="*res://game/world/cell_records.gd"
Toolkit="*res://game/dev/toolkit.gd"
HotReload="*res://game/dev/hot_reload.gd"
StrataLink="*res://game/dev/strata_link.gd"
MapScreen="*res://game/ui/map_screen.gd"
SaveGame="*res://game/save/save_manager.gd"
Settings="*res://game/ui/settings.gd"
PauseMenu="*res://game/ui/pause_menu.gd"
Skills="*res://game/skills/skills.gd"

[navigation]

; Per-cell baked navmesh tiles share border edges by design; at corners
; four regions meet and the merge warning fires on every sync. The
; engine's own guidance for tiled setups is to disable it.
3d/warnings/navmesh_edge_merge_errors=false

