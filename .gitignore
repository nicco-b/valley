# Godot
.godot/
*.tmp

# Blender backup saves (the .blend itself is versioned)
*.blend1

# macOS
.DS_Store

# The baked world tile: local cache of a Strata world_vN/ export —
# re-import with tools/strata/import_and_bake.sh <export dir> (the record
# under data/regions/ carries the source path + sha; P0 seam fix imports
# height.exr byte-identical, no re-erosion). P1's Bless/registry gives
# blessed worlds a committed home.
data/terrain/tiles/baked_*.exr
data/regions/baked_*.json
data/water/rivers/gen_*.json
# Strata hydrology records (ONE_APP P2): derived from the export's
# hydrology.json at import -- same regenerable cache as the tile.
data/water/rivers/hyd_*.json
data/water/hyd_*.json
# The importer's completion stamp: names which blessed world this checkout
# holds a full import of. Per-machine cache like the tile above (Strata
# re-runs the importer when it's missing/stale), never committed.
data/strata_import.json
# Blender terrain workspace: derived from the guide + cell records,
# regenerate with valley_terrain.py -- import.
assets/blender/terrain/valley_map.blend

# Placeholder synth asset drop (2026-07-06): binaries live ON DISK, UNTRACKED
# for now, pending the Git LFS decision (no LFS installed here yet). The tiny
# .card.json files ARE tracked -- they're the palette's source of truth and the
# real/placeholder ledger; the loader tolerates missing binaries. Regenerate the
# binaries any time with tools/placeholders/gen_billboards.py / gen_meshes.py.
assets/paintings/**/*.png
assets/paintings/**/*.png.import
assets/models/**/*.glb
assets/models/**/*.glb.import
tools/placeholders/contact_*.png
tools/placeholders/contact_*.png.import
