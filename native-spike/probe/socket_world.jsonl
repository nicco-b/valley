# socket_world(piece_pos, piece_yaw, piece_scale, local_pos, local_yaw)
#   -> {pos: vector3, yaw: float}
# Each line: [ {vec3 piece_pos}, {float piece_yaw}, {float piece_scale},
#             {vec3 local_pos}, {float local_yaw} ].
# --- identity: yaw 0, scale 1, local origin -> pos == piece_pos, yaw wrapped ---
[{"vec3":[0.0,0.0,0.0]},{"float":0.0},{"float":1.0},{"vec3":[0.0,0.0,0.0]},{"float":0.0}]
[{"vec3":[3.0,1.0,-2.0]},{"float":0.0},{"float":1.0},{"vec3":[0.0,0.0,0.0]},{"float":0.0}]
# --- local offset rides scale then the piece yaw ---
[{"vec3":[5.0,1.0,-2.0]},{"float":1.5707963267948966},{"float":1.0},{"vec3":[1.0,0.0,0.0]},{"float":0.0}]
[{"vec3":[0.0,0.0,0.0]},{"float":0.7853981633974483},{"float":2.0},{"vec3":[1.0,0.0,1.0]},{"float":0.0}]
# --- yaw sum wraps into [0, TAU): 6.0 + 1.0 = 7.0 -> 7 - TAU ---
[{"vec3":[0.0,0.0,0.0]},{"float":6.0},{"float":1.0},{"vec3":[0.5,0.0,0.0]},{"float":1.0}]
# --- negative yaw wraps up ---
[{"vec3":[1.0,2.0,3.0]},{"float":-1.0},{"float":1.5},{"vec3":[0.0,0.0,2.0]},{"float":-0.5}]
# --- zero and negative scale ---
[{"vec3":[2.0,0.0,2.0]},{"float":1.0},{"float":0.0},{"vec3":[3.0,4.0,5.0]},{"float":0.25}]
[{"vec3":[0.0,0.0,0.0]},{"float":2.0},{"float":-1.0},{"vec3":[1.0,0.0,0.0]},{"float":0.0}]
# --- arbitrary pose ---
[{"vec3":[-4.5,3.2,7.1]},{"float":2.9},{"float":0.75},{"vec3":[-1.0,2.0,-3.0]},{"float":1.3}]
# --- trig ULP boundary: piece_yaw 2.9415926 stresses the double-narrow sin/cos ---
[{"vec3":[0.0,0.0,0.0]},{"float":2.941592653589793},{"float":1.0},{"vec3":[0.5,0.0,0.0]},{"float":0.0}]
